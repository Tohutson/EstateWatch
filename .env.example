APP_ENV=production
LOG_LEVEL=INFO
DATA_DIR=/app/data
DATABASE_URL=
POSTAL_CODE=14221
SEARCH_RADIUS_MILES=35
LOOKAHEAD_DAYS=15
MIN_PICTURE_COUNT=5
ALLOWED_SALE_TYPES=EstateSales,MovingSales
ESTATESALES_BASE_URL=https://www.estatesales.net
HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=3
HTTP_REQUEST_DELAY_SECONDS=0.35
HTTP_USER_AGENT=Mozilla/5.0 (compatible; EstateSaleFinder/0.1; +https://github.com/tohutson/estate-sale-finder)
SALE_DETAIL_BATCH_SIZE=40
MAX_IMAGE_BYTES=15000000
MAX_IMAGE_PIXELS=24000000
MAX_DOWNLOAD_CONCURRENCY=4
KEEP_ORIGINAL_IMAGES=false
ANALYSIS_PROVIDER=mock
VISION_MODEL=gpt-4.1-mini
VISION_API_KEY=
VISION_BATCH_SIZE=4
VISION_MAX_BATCH_ATTEMPTS=2
VISION_MAX_SINGLE_IMAGE_ATTEMPTS=2
VISION_RETRY_BACKOFF_SECONDS=1
VISION_MAX_IMAGES_PER_RUN=
OPENAI_SAVE_RESPONSES=false
OPENAI_RESPONSE_LOG_DIR=
ANALYSIS_VERSION=multi-watchlist-v1
PROMPT_VERSION=targets-multi-v1
LOCAL_PREFILTER_ENABLED=false
LOCAL_PREFILTER_MODEL=ViT-B-32/laion2b_s34b_b79k
LOCAL_PREFILTER_THRESHOLD=0.20
EMAIL_ENABLED=false
EMAIL_SEND_ON_NO_MATCHES=false
EMAIL_SEND_ON_FAILURE=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=
EMAIL_TO=
WATCHLIST_CONFIG_PATH=
